generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  UserId       String   @id(map: "PK_User") @db.UniqueIdentifier
  Username     String?  @db.NChar(100)
  Email        String   @unique @db.NVarChar(255)
  PasswordHash String   @db.NVarChar(500)
  FirstName    String?  @db.NVarChar(100)
  LastName     String?  @db.NVarChar(100)
  IsActive     Boolean  @default(true)
  CreatedDate  DateTime @default(now())
  ModifiedDate DateTime @updatedAt
  Cards         Card[]
  RefreshTokens RefreshToken[]
}

model Card {
  CardId       String   @id(map: "PK_Card") @db.UniqueIdentifier
  Title        String   @db.NVarChar(255)
  Description  String?  @db.NVarChar(1000)
  Tags         String?  @db.NVarChar(500)
  IsFavorite   Boolean  @default(false)
  IsActive     Boolean  @default(true)
  IsDeleted    Boolean  @default(false)
  CreatedDate  DateTime @default(now())
  ModifyDate   DateTime @updatedAt
  UserId       String   @db.UniqueIdentifier
  User         User     @relation(fields: [UserId], references: [UserId], map: "FK_Card_User")
  Fretboards   Fretboard[]
}

model Fretboard {
  FretboardId    String   @id(map: "PK_Fretboard") @db.UniqueIdentifier
  CardId         String   @db.UniqueIdentifier
  Accidental     String   @db.NVarChar(10)
  Key            String   @db.NVarChar(5)
  Pattern        String   @db.NVarChar(100)
  Setup          String   @db.NVarChar(50)
  Tonality       String   @db.NVarChar(20)
  ChordPosition  Int
  FretAmount     Int
  HighlightNotes String   @db.NVarChar(500)
  CAGED          String   @db.NVarChar(500)
  Strings        String   @db.NVarChar(500)
  IsActive       Boolean  @default(true)
  CreatedDate    DateTime @default(now())
  ModifiedDate   DateTime @updatedAt
  Card           Card     @relation(fields: [CardId], references: [CardId], map: "FK_Fretboard_Card")
}

model RefreshToken {
  TokenId     String   @id(map: "PK_RefreshToken") @db.UniqueIdentifier
  Token       String   @unique @db.NVarChar(500)
  UserId      String   @db.UniqueIdentifier
  ExpiresAt   DateTime
  CreatedDate DateTime @default(now())
  User        User     @relation(fields: [UserId], references: [UserId], map: "FK_RefreshToken_User")
}
